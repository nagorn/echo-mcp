{
  "openapi": "3.0.3",
  "info": {
    "title": "Array Ref Response Corpus Fixture",
    "version": "1.0.0"
  },
  "paths": {
    "/widgets": {
      "get": {
        "responses": {
          "200": {
            "description": "Widget list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["items"],
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Widget"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Widget": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"}
        }
      }
    }
  }
}
